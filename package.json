{
  "name": "zustand-hash-store",
  "version": "0.0.1",
  "description": "Zustand store that syncs state with the URL hash fragment",
  "type": "module",
  "license": "MIT",
  "author": "Garbo Succus",
  "repository": {
    "type": "git",
    "url": "https://github.com/neftaly/zustand-hash-store"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
