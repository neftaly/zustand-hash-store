  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "jsdom": "^28.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
